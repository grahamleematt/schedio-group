# DocuPipe (server-only; never shipped to the browser)
# See docs/docupipe-setup.md for how to generate each value.
DOCUPIPE_API_KEY=
DOCUPIPE_BASE_URL=https://app.docupipe.ai
DOCUPIPE_WORKFLOW_ID=
DOCUPIPE_WEBHOOK_SECRET=

# AWS RDS Postgres for Schedio app data
DATABASE_URL=
DATABASE_SSL=true

# Egnyte (SG DREAM Layer 1 custody; server-only)
# See docs/egnyte-setup.md for app registration + refresh-token generation.
EGNYTE_DOMAIN=
EGNYTE_CLIENT_ID=
EGNYTE_CLIENT_SECRET=
EGNYTE_REFRESH_TOKEN=
EGNYTE_ROOT_PATH=/Shared/Clients
# One-time OAuth mint only; must be https and match the Egnyte API key redirect URI.
EGNYTE_REDIRECT_URI=https://localhost/callback

# Vercel KV (legacy fallback; AWS Postgres is preferred for Tim staging)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# WorkOS for SG DREAM auth
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_ORGANIZATION_ID=
WORKOS_TIM_EMAIL=tim.mccarley@schedio.example
WORKOS_TIM_USER_ID=
# Local default: http://localhost:3000/api/auth/callback
# Vercel preview/prod: https://<domain>/api/auth/callback
WORKOS_REDIRECT_URI=
# Generate with: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=

# AI providers for embeddings and structured reasoning
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_MODEL=gpt-5.2

# --- Runtime posture flags ---
# Strict staging/production: require Postgres + WorkOS, no dev fallbacks,
# lock Egnyte imports to the entity intake folder. Set true on Vercel.
SG_DREAM_STRICT_MODE=false
# Master switch for the real intake pipeline (uploads/imports -> DocuPipe).
# Keep false during setup/preflight; flip true for an intentional real test.
INTAKE_PIPELINE_ENABLED=false
# Unfinished Intelligence + Determinations workbenches. Off everywhere except
# local development when you are actively working on them.
INTELLIGENCE_PREVIEW_ENABLED=false
